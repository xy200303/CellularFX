[configuration]
entry_symbol = "cellular_automata_library_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]
windows.debug.x86_64 = "res://addons/cellular_automata_engine/bin/libcellauto.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/cellular_automata_engine/bin/libcellauto.windows.template_release.x86_64.dll"
macos.debug = "res://addons/cellular_automata_engine/bin/libcellauto.macos.template_debug.framework"
macos.release = "res://addons/cellular_automata_engine/bin/libcellauto.macos.template_release.framework"
macos.debug.arm64 = "res://addons/cellular_automata_engine/bin/libcellauto.macos.template_debug.arm64.framework"
macos.release.arm64 = "res://addons/cellular_automata_engine/bin/libcellauto.macos.template_release.arm64.framework"
linux.debug.x86_64 = "res://addons/cellular_automata_engine/bin/libcellauto.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://addons/cellular_automata_engine/bin/libcellauto.linux.template_release.x86_64.so"
linux.debug.arm64 = "res://addons/cellular_automata_engine/bin/libcellauto.linux.template_debug.arm64.so"
linux.release.arm64 = "res://addons/cellular_automata_engine/bin/libcellauto.linux.template_release.arm64.so"
linux.debug.rv64 = "res://addons/cellular_automata_engine/bin/libcellauto.linux.template_debug.rv64.so"
linux.release.rv64 = "res://addons/cellular_automata_engine/bin/libcellauto.linux.template_release.rv64.so"
android.debug.x86_64 = "res://addons/cellular_automata_engine/bin/libcellauto.android.template_debug.x86_64.so"
android.release.x86_64 = "res://addons/cellular_automata_engine/bin/libcellauto.android.template_release.x86_64.so"
android.debug.arm64 = "res://addons/cellular_automata_engine/bin/libcellauto.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/cellular_automata_engine/bin/libcellauto.android.template_release.arm64.so"

[icons]
CASWorld = "res://addons/cellular_automata_engine/icons/cas_world.svg"
